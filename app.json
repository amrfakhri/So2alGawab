{
  "expo": {
    "name": "So2alGawab",
    "slug": "seenjeem-mvp",
    "scheme": "so2algawab",
    "version": "0.1.2",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F7F1E8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amrfakhri.so2algawab",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIViewControllerBasedStatusBarAppearance": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F1E8"
      },
      "package": "com.amrfakhri.so2algawab",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "so2algawab"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-asset",
      "expo-localization",
      "expo-updates",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "So2alGawab needs camera access to scan the TV pairing QR code."
        }
      ],
      "expo-web-browser",
      "expo-audio",
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "4bbc6c82-39fa-4db3-badf-23870acba098"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4bbc6c82-39fa-4db3-badf-23870acba098",
      "enabled": true
    }
  }
}
